// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// ─────────────────────────────────────────────
// Ресторан (справочник, 39 фиксированных записей)
// ─────────────────────────────────────────────
model Restaurant {
  id          Int    @id @default(autoincrement())
  brandName   String
  legalEntity String
  address     String // полный адрес строкой
  inn         String // ИНН (10 цифр)
  kpp         String // КПП (9 цифр)
  vatPercent  Int    @default(20)
  start       String // "10:00:00" — время начала работы
  end         String // "20:00:00" — время конца работы
  timeZone    String // "Europe/Moscow"

  orders Order[]

  @@index([brandName])
  @@map("restaurants")
}

// ─────────────────────────────────────────────
// Корневая модель заказа
// ─────────────────────────────────────────────
model Order {
  id        Int    @id @default(autoincrement())
  orderDate String // ISO / Unix timestamp / dd.mm.yyyy — храним как есть
  currency  String @default("RUB")
  status    String // "Новый", "Готовится", "Передан курьеру", "Доставляется", "Доставлен", "Отменен"
  createdAt String // ISO строка
  updatedAt String // ISO строка

  // Финансовые поля (перенесены из financial_summaries)
  subtotal       String // String: может быть "1500,50 руб."
  taxAmount      String
  deliveryFee    String
  serviceFee     String
  discountAmount String
  grandTotal     String
  paymentMethod  String // "CARD_ONLINE", "CASH", "APPLE_PAY", "GOOGLE_PAY", "SBP"

  // Связь с покупателем
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  // Связь с рестораном
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  orderItems OrderItem[]

  orderOptionsId Int?          @unique
  orderOptions   OrderOptions? @relation(fields: [orderOptionsId], references: [id])

  courierId Int?
  courier   Courier? @relation(fields: [courierId], references: [id])

  reviewId Int?    @unique
  review   Review? @relation(fields: [reviewId], references: [id])

  @@index([status])
  @@index([paymentMethod])
  @@index([id(sort: Desc)])
  @@map("orders")
}

// ─────────────────────────────────────────────
// Покупатель (id — первичный ключ)
// ─────────────────────────────────────────────
model Customer {
  id       Int    @id @default(autoincrement())
  fullName String
  phone    String // разные форматы: +7-..., 8..., +7...
  email    String

  deliveryAddressId Int?             @unique
  deliveryAddress   DeliveryAddress? @relation(fields: [deliveryAddressId], references: [id])
  orders            Order[]

  @@index([fullName])
  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ─────────────────────────────────────────────
// Адрес доставки (1:1 с Customer)
// ─────────────────────────────────────────────
model DeliveryAddress {
  id               Int     @id @default(autoincrement())
  city             String
  street           String
  building         String // "15/2"
  apartment        String
  entrance         String
  floor            Int
  intercom         String // "123#"
  postalCode       String
  deliveryTimeZone String? // "+03:00" или "Europe/Moscow"

  customer Customer?

  coordinatesId Int?         @unique
  coordinates   Coordinates? @relation(fields: [coordinatesId], references: [id])

  @@map("delivery_addresses")
}

// ─────────────────────────────────────────────
// Координаты адреса (1:1 с DeliveryAddress)
// ─────────────────────────────────────────────
model Coordinates {
  id  Int    @id @default(autoincrement())
  lat String
  lon String

  deliveryAddress DeliveryAddress?

  @@map("coordinates")
}

// ─────────────────────────────────────────────
// Позиция заказа (1:N с Order)
// ─────────────────────────────────────────────
model OrderItem {
  id                  Int     @id @default(autoincrement())
  name                String // название блюда
  quantity            String // String: может быть "3 шт." из-за «порчи»
  pricePerUnit        String // String: может быть "500,00 руб." из-за «порчи»
  category            String // "Горячие блюда", "Десерты" и т.д.
  specialInstructions String? // пожелания или null

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ─────────────────────────────────────────────
// Опции заказа (1:1 с Order)
// ─────────────────────────────────────────────
model OrderOptions {
  id                          Int     @id @default(autoincrement())
  numberOfCutlery             Int // 0–5
  requiresContactlessDelivery Boolean
  isEcoFriendlyPackaging      Boolean

  order Order?

  @@map("order_options")
}

// ─────────────────────────────────────────────
// Курьер
// ─────────────────────────────────────────────
model Courier {
  id               Int    @id @default(autoincrement())
  name             String
  transportType    String // "bicycle", "car", "walking", "scooter"
  phone            String // "+79991234567"
  estimatedArrival String // "14:30" или "02:30 PM"

  orders Order[]

  locationId Int?             @unique
  location   CourierLocation? @relation(fields: [locationId], references: [id])

  @@index([name])
  @@map("couriers")
}

// ─────────────────────────────────────────────
// Текущее местоположение курьера
// ─────────────────────────────────────────────
model CourierLocation {
  id  Int   @id @default(autoincrement())
  lat Float
  lon Float

  courier Courier?

  @@map("courier_locations")
}

// ─────────────────────────────────────────────
// Отзыв (1:1 с Order, опциональный)
// ─────────────────────────────────────────────
model Review {
  id      Int    @id @default(autoincrement())
  rating  Float // 0.5–5.0 (шаг 0.5)
  comment String

  order Order?

  @@map("reviews")
}
