# ---------- Infrastructure ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=big_data_service
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---------- Application ----------
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/big_data_service?schema=public
GEOAPIFY_API_KEY=put_your_real_key_here
REDIS_URL=redis://localhost:6379

# ---------- Auto generation ----------
AUTO_GENERATE=false
AUTO_GENERATE_BATCH_SIZE=20
AUTO_GENERATE_INTERVAL=1000

# ---------- Generation performance ----------
ORDER_GENERATION_CONCURRENCY=24
DB_WRITE_CHUNK_SIZE=20
MAX_QUEUED_DB_BATCHES=4

# ---------- Geocoding ----------
GEOCODING_CONCURRENCY=5
GEOAPIFY_TIMEOUT_MS=1500
GEOCODING_RETRIES=1
GEOCODING_MIN_TIME_MS=0
SHARED_GEOCACHE_ENABLED=true

# ---------- Shared market state ----------
SHARED_MARKET_STATE_ENABLED=true
MARKET_PROFILE_SEED=demo-market
MARKET_RUN_SEED=run-2026-04-21-01
